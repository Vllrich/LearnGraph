  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "drizzle-orm": "^0.39.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
