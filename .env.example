# ╔══════════════════════════════════════════════════════════════════╗
# ║  LearnGraph — Environment Variables                            ║
# ║  Copy to .env and fill in your real values                     ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Supabase ────────────────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── AI Providers ────────────────────────────────────────────────────
# Which LLM backend to use: "openai" or "anthropic"
LLM_PROVIDER=openai

# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
# Primary model (used when LLM_PROVIDER=openai)
OPENAI_MODEL=gpt-4.1
# Fallback for lighter/cheaper tasks
OPENAI_MODEL_FALLBACK=gpt-4.1-mini
# Embeddings for vector search
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...
# Primary model (used when LLM_PROVIDER=anthropic)
ANTHROPIC_MODEL=claude-sonnet-4-5-20250514

# ── Redis (Upstash) — OPTIONAL ─────────────────────────────────────
# https://console.upstash.com
# Used as a *helper* only:
#   - distributed rate-limiting (falls back to per-instance in-memory)
#   - embedding cache
#   - cron sweeper tick-lock (falls back to DB-only atomic claim)
# The progressive course-generation feature does NOT depend on Redis;
# Postgres is the canonical source of truth for all module/course state.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...your-token

# ── Email (Brevo) ──────────────────────────────────────────────────
# https://app.brevo.com/settings/keys/api — transactional email API key
BREVO_API_KEY=xkeysib-...

# Must be a verified sender in Brevo → Settings → Senders & IPs
BREVO_SENDER_EMAIL=noreply@yourdomain.com

# ── Cron Security ──────────────────────────────────────────────────
# Random secret to protect cron endpoints from public access
# On Vercel Pro, this is auto-set. Otherwise generate one:
#   openssl rand -base64 32
CRON_SECRET=your-random-secret-here

# ── Feature Flags ──────────────────────────────────────────────────
# Gate for progressive course generation (module-1-first, SSE lifecycle,
# auto-redirect into lesson 1, per-module retry UI, stuck-module sweeper).
# Unset → defaults to "true" in dev and "false" in prod.
# Set explicitly ("true"/"false") to force the behavior regardless of env.
PROGRESSIVE_COURSE_GENERATION=false
# Public mirror so the client bundle can read the same flag.
NEXT_PUBLIC_PROGRESSIVE_COURSE_GENERATION=false

# ── Progressive Generation: Sweeper Tuning (optional) ──────────────
# Only read when PROGRESSIVE_COURSE_GENERATION is effectively enabled.
# COURSE_STUCK_THRESHOLD_MINUTES=10
# COURSE_SWEEP_MAX_BATCH=20
# COURSE_SWEEP_MAX_ATTEMPTS=5
# COURSE_MODULE_JOB_CONCURRENCY=4

# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
